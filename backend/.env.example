# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/organizaterd_db"

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# pgAdmin (optional, for local dev)
PGADMIN_EMAIL=admin@organizaterd.com
PGADMIN_PASSWORD=admin
